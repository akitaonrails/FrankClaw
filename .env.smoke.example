# FrankClaw Smoke Test Configuration
# Copy this to .env.smoke and fill in your API keys.
#
# Usage:
#   cp .env.smoke.example .env.smoke
#   # Edit .env.smoke with your real keys
#   source .env.smoke
#   cargo test -p frankclaw-models --test smoke -- --ignored
#
# You only need keys for the providers you want to test.
# Tests for providers without keys will panic with a clear message.

# OpenAI — https://platform.openai.com/api-keys
export OPENAI_API_KEY=""

# Anthropic — https://console.anthropic.com/settings/keys
export ANTHROPIC_API_KEY=""

# Ollama — no key needed, just have it running:
#   ollama serve
#   ollama pull llama3.1
